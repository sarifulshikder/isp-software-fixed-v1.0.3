# ═══════════════════════════════════════════════════════
# ISP Billing & Management Software - Environment Config
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════

# ─────────────────────────────────────────
# Django
# ─────────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-this-in-production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com
CORS_ALLOWED_ORIGINS=http://localhost,https://yourdomain.com

# Optional: Sentry error tracking - leave empty to disable
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
APP_VERSION=1.0.1

# ─────────────────────────────────────────
# Database (PostgreSQL)
# ─────────────────────────────────────────
DB_NAME=ispdb
DB_USER=ispuser
DB_PASSWORD=strong_db_password_here
DB_HOST=db
DB_PORT=5432

# ─────────────────────────────────────────
# Redis
# ─────────────────────────────────────────
REDIS_HOST=redis
REDIS_PASSWORD=strong_redis_password_here

# ─────────────────────────────────────────
# Ports
# ─────────────────────────────────────────
HTTP_PORT=80
HTTPS_PORT=443

# ─────────────────────────────────────────
# ISP Company Settings
# ─────────────────────────────────────────
COMPANY_NAME=My Internet Service Provider
COMPANY_ADDRESS=123 Main Street, Dhaka, Bangladesh
COMPANY_PHONE=+8801XXXXXXXXX
COMPANY_EMAIL=info@myisp.com
CURRENCY=BDT
CURRENCY_SYMBOL=৳
TAX_RATE=0.0
LATE_FEE_RATE=2.0
GRACE_PERIOD_DAYS=7
BILLING_DATE=1

# ─────────────────────────────────────────
# Email (SMTP)
# ─────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your@gmail.com
EMAIL_HOST_PASSWORD=your_app_password
DEFAULT_FROM_EMAIL=noreply@myisp.com

# ─────────────────────────────────────────
# SMS (Twilio)
# ─────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ─────────────────────────────────────────
# RADIUS Server
# ─────────────────────────────────────────
RADIUS_HOST=freeradius
RADIUS_PORT=1812
RADIUS_SECRET=radius_shared_secret

# ─────────────────────────────────────────
# Mikrotik Router
# ─────────────────────────────────────────
MIKROTIK_HOST=192.168.1.1
MIKROTIK_USER=admin
MIKROTIK_PASSWORD=mikrotik_password

# ─────────────────────────────────────────
# Payment Gateways
# ─────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_xxxxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxxxx
BKASH_APP_KEY=
BKASH_APP_SECRET=
NAGAD_MERCHANT_ID=

# ─────────────────────────────────────────
# Monitoring
# ─────────────────────────────────────────
SENTRY_DSN=

# ─────────────────────────────────────────
# Admin Tools
# ─────────────────────────────────────────
PGADMIN_EMAIL=admin@isp.local
PGADMIN_PASSWORD=admin_password
FLOWER_USER=admin
FLOWER_PASSWORD=flower_password
